# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_reporting
DB_USERNAME=retail_app
DB_PASSWORD=change_me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_base64_secret_at_least_256_bits
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- App ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- Admin bootstrap user (created on first migration only if not present) ---
ADMIN_BOOTSTRAP_EMAIL=admin@retail-reporting.local
ADMIN_BOOTSTRAP_PASSWORD=change_me_immediately
