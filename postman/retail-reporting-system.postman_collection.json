{
  "info": {
    "name": "Retail Reporting System",
    "description": "REST API collection for the Retail Reporting System. Import this alongside a Postman environment defining `baseUrl` (default http://localhost:8080). Run 'Login as Manager' first - its test script stores the returned accessToken into the collection variable {{accessToken}}, which every other request's Authorization header references automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Login as Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.test('login succeeded', () => pm.response.code === 200);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@retail-reporting.local\",\n  \"password\": \"Manager@12345\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste-a-refresh-token-here\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/categories"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Toys\",\n  \"description\": \"Kids toys and games\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?active=true&page=0&size=20&sort=price,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "active", "value": "true" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "price,desc" }
              ]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"NEW-0001\",\n  \"name\": \"New Product\",\n  \"description\": \"Created via Postman\",\n  \"categoryId\": 1,\n  \"price\": 29.99,\n  \"costPrice\": 12.00,\n  \"active\": true,\n  \"initialQuantity\": 50,\n  \"reorderLevel\": 10,\n  \"warehouseLocation\": \"WH1-A1\"\n}"
            }
          }
        },
        {
          "name": "Get Product Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/products/1/inventory"
          }
        },
        {
          "name": "Adjust Product Inventory",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/products/1/inventory",
            "body": { "mode": "raw", "raw": "{\n  \"quantityDelta\": 20,\n  \"reason\": \"restock\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Search Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/customers?page=0&size=20"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"New\",\n  \"lastName\": \"Customer\",\n  \"email\": \"new.customer@example.com\",\n  \"phone\": \"555-0100\",\n  \"address\": \"1 Main St\",\n  \"city\": \"Bloomington\",\n  \"state\": \"IN\",\n  \"zipCode\": \"47401\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Search Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/orders?page=0&size=20"
          }
        },
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": [ { \"productId\": 1, \"quantity\": 2 } ]\n}"
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/orders/1/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"PROCESSING\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Sales Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/sales-summary?start=2026-01-01T00:00:00&end=2026-07-07T00:00:00"
          }
        },
        {
          "name": "Revenue Trend (Monthly)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/revenue-trend?start=2026-01-01T00:00:00&end=2026-07-07T00:00:00&granularity=MONTHLY"
          }
        },
        {
          "name": "Top Products by Revenue (CSV export)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/top-products?start=2026-01-01T00:00:00&end=2026-07-07T00:00:00&limit=10&sortBy=revenue&format=csv"
          }
        },
        {
          "name": "Top Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/top-customers?start=2026-01-01T00:00:00&end=2026-07-07T00:00:00&limit=10"
          }
        },
        {
          "name": "Low Stock (PDF export)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/low-stock?format=pdf"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "KPI Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/dashboard/summary?lookbackDays=30"
          }
        }
      ]
    }
  ]
}
